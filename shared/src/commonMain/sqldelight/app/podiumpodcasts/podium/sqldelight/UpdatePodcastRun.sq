CREATE TABLE IF NOT EXISTS statisticsUpdatePodcastRun (
    timestamp INTEGER NOT NULL PRIMARY KEY,
    dataUsage INTEGER NOT NULL
);

SELECT * FROM statisticsUpdatePodcastRun ORDER BY timestamp DESC;

SELECT * FROM statisticsUpdatePodcastRun WHERE timestamp > ?;

INSERT OR IGNORE INTO statisticsUpdatePodcastRun (timestamp, dataUsage) VALUES (?, ?);

DELETE FROM statisticsUpdatePodcastRun WHERE timestamp < ?;
